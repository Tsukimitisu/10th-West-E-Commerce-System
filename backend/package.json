{
  "name": "10th-west-moto-backend",
  "version": "1.0.0",
  "description": "Backend API for 10th West Moto E-Commerce System",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "knex migrate:latest --knexfile knexfile.cjs",
    "migrate:down": "knex migrate:rollback --knexfile knexfile.cjs",
    "migrate:status": "knex migrate:status --knexfile knexfile.cjs",
    "migrate:make": "knex migrate:make --knexfile knexfile.cjs",
    "migrate:legacy": "node src/database/migrate.js",
    "migrate:auth:legacy": "node src/database/migrate-auth.js"
  },
  "keywords": [
    "ecommerce",
    "api",
    "express",
    "postgresql"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.100.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-session": "^1.19.0",
    "express-validator": "^7.0.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.0",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "sanitize-html": "^2.17.2",
    "socket.io": "^4.8.3",
    "speakeasy": "^2.0.0",
    "stripe": "^20.3.1"
  },
  "devDependencies": {
    "knex": "^3.1.0",
    "nodemon": "^3.0.2"
  }
}
