# Canonical backend environment file
# Copy this file to backend/.env. The backend always loads that exact file;
# variables already present in process.env take precedence over file values.
# Root and frontend .env files are not read by the backend.

# Database
# Copy the exact URI shown by Supabase Dashboard > Connect. Prefer setting only
# DATABASE_URL. SUPABASE_DB_URL is a supported alias, not an override: if both
# are set, their values must match after surrounding whitespace is trimmed.
DATABASE_URL=
SUPABASE_DB_URL=

# Direct database configuration with NODE_ENV=test is fail-closed and requires
# a separate explicit test URL. The npm test wrapper supplies an unreachable
# local sentinel when none is provided, so unit tests cannot reach another URL.
TEST_DATABASE_URL=

# Supabase URI shapes (documentation only; do not paste literal angle-bracket
# values):
# Direct:      postgresql://postgres:<encoded-password>@db.<project-ref>.supabase.co:5432/postgres
# Session:     postgresql://postgres.<project-ref>:<encoded-password>@<region>.pooler.supabase.com:5432/postgres
# Transaction: postgresql://postgres.<project-ref>:<encoded-password>@<region>.pooler.supabase.com:6543/postgres
# Use the exact host and username supplied by the dashboard. Percent-encode
# reserved password characters before placing them in a URI. Prefer direct or
# session mode for a persistent server and migrations; transaction mode is for
# constrained/serverless connections.
# Supabase requires TLS. Production always verifies the certificate chain and
# defaults to verify-full; non-production defaults to require. Download the
# project CA from Dashboard > Database Settings > SSL Configuration and set
# NODE_EXTRA_CA_CERTS in the process environment before Node starts. Putting it
# only in backend/.env is too late for Node's trust-store initialization. Never
# disable TLS for Supabase.
DB_SSL_MODE=
DB_POOL_MIN=0
DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT_MS=5000
DB_IDLE_TIMEOUT_MS=30000
DB_QUERY_TIMEOUT_MS=10000
DB_STATEMENT_TIMEOUT_MS=10000

# Core reads use PostgreSQL. Supabase REST fallback is optional and requires the
# project URL plus a service-role key kept on the server. Leave the key empty
# unless that fallback is deliberately enabled; never expose it as VITE_*.
DB_READ_MODE=postgres
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_REST_TIMEOUT_MS=10000
DB_READ_FALLBACK_TTL_MS=600000

# Server Configuration
PORT=5000
NODE_ENV=development

# Production requires an HTTPS FRONTEND_ORIGIN, PostgreSQL-backed sessions,
# secure cookies, and four distinct non-placeholder secrets of at least 32
# characters. Generate and inject secrets through the deployment platform;
# never save production values in this file or commit them.

# Authentication and server-side sessions
# JWT_SECRET is required in every environment. Production validates all four
# secrets below for strength and uniqueness.
JWT_SECRET=
SESSION_SECRET=
CSRF_SECRET=
TWO_FACTOR_ENCRYPTION_KEY=
SESSION_STORE=postgres
SESSION_TTL=7d
SESSION_CLEANUP_INTERVAL_MS=300000
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
CSRF_COOKIE_SAME_SITE=lax

# Canonical frontend origin (redirects and CORS). FRONTEND_URL remains a legacy
# development alias only; production requires FRONTEND_ORIGIN.
FRONTEND_ORIGIN=http://localhost:3000
# Additional production entries must be comma-separated absolute HTTPS origins.
CORS_ALLOWED_ORIGINS=

# PayMongo / GCash status: Blocked by credentials/configuration.
# Leave credentials empty until the real provider configuration is available.
PAYMONGO_PUBLIC_KEY=
PAYMONGO_SECRET_KEY=
PAYMONGO_WEBHOOK_SECRET=
PAYMONGO_WEBHOOK_TOLERANCE_SECONDS=300
PUBLIC_APP_URL=http://localhost:3000
PAYMONGO_SUCCESS_URL=http://localhost:3000/#/payment-result?order={orderId}&status=success
PAYMONGO_FAILED_URL=http://localhost:3000/#/payment-result?order={orderId}&status=failed
PAYMONGO_CANCEL_URL=http://localhost:3000/#/payment-result?order={orderId}&status=cancelled

# Prices are VAT-inclusive by default. Set only if tax must be added at checkout.
CHECKOUT_TAX_RATE=0
DEFAULT_SHIPPING_FEE=150
FREE_SHIPPING_THRESHOLD=2500

# Email Configuration (Gmail or any SMTP). Leave empty until configured.
EMAIL_PROVIDER=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
# Legacy aliases currently read by the application mailers.
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=
SUPPORT_EMAIL=

# Philippine shipping/waybill status: Blocked by credentials/configuration.
# Provider choices: bigseller | mock
# Production route: J&T Express Philippines through BigSeller.
# Mock produces clearly marked simulated records and is blocked in production.
SHIPPING_PROVIDER=bigseller
SHIPPING_COUNTRY=PH
SHIPPING_CARRIER=jtexpress-ph
BIGSELLER_API_BASE_URL=
BIGSELLER_APP_KEY=
BIGSELLER_APP_SECRET=
BIGSELLER_ACCESS_TOKEN=
BIGSELLER_WEBHOOK_SECRET=
BIGSELLER_WAREHOUSE_ID=
BIGSELLER_JT_PH_VIP_CODE=
MOCK_SHIPPING_RATE=150

# Tracking status: Blocked by credentials/configuration.
# Provider choices: shipping_provider | aftership | mock
# TrackingMore variables are reserved until its adapter contract is implemented.
TRACKING_PROVIDER=aftership
TRACKING_PROVIDER_TIMEOUT_MS=10000
AFTERSHIP_API_BASE_URL=https://api.aftership.com/tracking/2026-01
AFTERSHIP_API_KEY=
AFTERSHIP_WEBHOOK_SECRET=
TRACKINGMORE_API_BASE_URL=
TRACKINGMORE_API_KEY=
TRACKINGMORE_WEBHOOK_SECRET=

# Sender details supplied to the configured shipping provider.
SHIPPER_NAME=10th West Moto
SHIPPER_PHONE=
SHIPPER_EMAIL=
SHIPPER_ADDRESS_LINE1=
SHIPPER_ADDRESS_LINE2=
SHIPPER_PROVINCE=
SHIPPER_CITY=
SHIPPER_BARANGAY=
SHIPPER_POSTAL_CODE=
SHIPPER_COUNTRY=PH

# Background cleanup workers
RESERVATION_CLEANUP_INTERVAL_MS=60000
MAINTENANCE_CLEANUP_INTERVAL_MS=300000
MAINTENANCE_CLEANUP_DISABLED=false

# OAuth providers. Leave empty until the provider app is configured.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Cloudinary Storage (durable media storage for all uploads: products, avatars, reviews)
# Leave empty to keep uploads blocked by configuration.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional root folder namespace (recommended per environment, e.g. 10th-west-moto-prod)
CLOUDINARY_UPLOAD_ROOT=10th-west-moto
