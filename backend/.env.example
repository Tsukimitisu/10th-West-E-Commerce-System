# Database Configuration
# Supabase Postgres connection string
# Get this from Supabase Dashboard > Project Settings > Database > Connection string (URI)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
# Optional alias used by backend (if set, takes priority over DATABASE_URL)
SUPABASE_DB_URL=

# Supabase project URL and server-side key (for supabase-js usage in backend services)
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Server Configuration
PORT=5000
NODE_ENV=development

# Auth/session secrets (MUST change these in production!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
SESSION_SECRET=replace_with_at_least_32_random_bytes
CSRF_SECRET=replace_with_at_least_32_random_bytes
SESSION_STORE=postgres
SESSION_TTL=7d
SESSION_CLEANUP_INTERVAL_MS=300000
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
CSRF_COOKIE_SAME_SITE=lax

# Frontend URL/origin (for redirects and CORS)
FRONTEND_URL=http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3000
CORS_ALLOWED_ORIGINS=

# PayMongo / GCash. All three are mandatory in production.
PAYMONGO_SECRET_KEY=sk_test_your_paymongo_secret_key
PAYMONGO_PUBLIC_KEY=pk_test_your_paymongo_public_key
PAYMONGO_WEBHOOK_SECRET=whsk_your_paymongo_webhook_secret
PAYMONGO_WEBHOOK_TOLERANCE_SECONDS=300
PUBLIC_APP_URL=http://localhost:3000
PAYMONGO_SUCCESS_URL=http://localhost:3000/#/payment-result?order={orderId}&status=success
PAYMONGO_FAILED_URL=http://localhost:3000/#/payment-result?order={orderId}&status=failed
PAYMONGO_CANCEL_URL=http://localhost:3000/#/payment-result?order={orderId}&status=cancelled

# Prices are VAT-inclusive by default. Set only if tax must be added at checkout.
CHECKOUT_TAX_RATE=0
DEFAULT_SHIPPING_FEE=150

# Email Configuration (Gmail or any SMTP)
# For Gmail: Use App Password (https://myaccount.google.com/apppasswords)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_FROM=Your App Name <your_email@gmail.com>

# J&T Express Philippines integration
# Keep mock mode enabled locally. Disable only after the signed J&T agreement,
# sandbox mapping, and production credentials are complete.
JNT_MODE=sandbox
JNT_MOCK_MODE=true
JNT_API_BASE_URL=
JNT_TRACKING_API_BASE_URL=
JNT_SANDBOX_URL=
JNT_SANDBOX_TRACKING_URL=
JNT_PRODUCTION_URL=
JNT_PRODUCTION_TRACKING_URL=
JNT_USERNAME=
JNT_API_KEY=
JNT_CUSTOMER_CODE=
JNT_SECRET_KEY=
JNT_SIGNING_KEY=
JNT_SENDER_NAME=10th West Moto
JNT_SENDER_CONTACT=10th West Moto
JNT_SENDER_PHONE=
JNT_SENDER_ADDRESS=
JNT_SENDER_ZIP=
JNT_ORIGIN_CODE=
JNT_ORIGIN_AREA_CODE=
JNT_WEBHOOK_SECRET=replace_with_a_long_random_secret
COURIER_WEBHOOK_SECRET=
JNT_DEFAULT_WEIGHT_KG=1
JNT_SERVICE_TYPE=1
JNT_EXPRESS_TYPE=1

# Background cleanup workers
RESERVATION_CLEANUP_INTERVAL_MS=60000
MAINTENANCE_CLEANUP_INTERVAL_MS=300000
MAINTENANCE_CLEANUP_DISABLED=false

# Cloudinary Storage (durable media storage for all uploads: products, avatars, reviews)
# Get these from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
# Optional root folder namespace (recommended per environment, e.g. 10th-west-moto-prod)
CLOUDINARY_UPLOAD_ROOT=10th-west-moto
