{
  "name": "10th-west-moto",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "postinstall": "npm run install:frontend && npm run install:backend",
    "dev": "npm --prefix frontend run dev",
    "dev:frontend": "npm --prefix frontend run dev:frontend",
    "dev:backend": "npm --prefix backend run dev",
    "build": "npm --prefix frontend run build",
    "install:frontend": "npm --prefix frontend install --legacy-peer-deps",
    "install:backend": "npm --prefix backend install",
    "install:all": "npm run install:frontend && npm run install:backend",
    "start": "npm --prefix backend run start"
  }
}
