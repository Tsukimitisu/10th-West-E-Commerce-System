# Frontend local environment template
# Copy to frontend/.env.local
# The Vite development server is served at http://localhost:3000.

# Backend API URL
VITE_API_URL=http://localhost:5000/api

# Optional: mock mode for UI-only testing
VITE_USE_MOCK=false

# Supabase and application database credentials belong on the backend only.
# Never put a service-role key, database URL, password, or other secret in a
# VITE_* variable: Vite exposes those values to the browser bundle.
