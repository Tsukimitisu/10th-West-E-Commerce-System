# Frontend local environment template
# Copy to frontend/.env.local

# Backend API URL
VITE_API_URL=http://localhost:5000/api

# Direct Supabase access is disabled for application data. Keep this false.
VITE_USE_SUPABASE=false

# Optional: mock mode for UI-only testing
VITE_USE_MOCK=false

# Supabase credentials belong on the backend only. Do not add service-role or
# application database credentials to Vite variables.
