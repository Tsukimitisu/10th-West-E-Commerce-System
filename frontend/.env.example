# Frontend local environment template
# Copy to frontend/.env.local

# Backend API URL
VITE_API_URL=http://localhost:5000/api

# Set to true only if frontend should read/write directly to Supabase
VITE_USE_SUPABASE=false

# Optional: mock mode for UI-only testing
VITE_USE_MOCK=false

# Supabase (required only when VITE_USE_SUPABASE=true)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_supabase_anon_key_here

